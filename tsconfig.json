{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES2020",
		"allowJs": false,
		"noImplicitAny": true,
		"moduleResolution": "node",
		"importHelpers": true,
		"strictNullChecks": true,
		"lib": ["DOM", "ES2020"],
		"paths": {
			"obsidian": [
				"node_modules/obsidian",
				"../TimeGrid/node_modules/obsidian"
			]
		}
	},
	"include": ["src/**/*.ts"]
}
